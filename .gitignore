# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local database (and any backups/snapshots of it)
local.db
local.db.*

# transient script outputs (regenerated on demand from prod)
scripts/april_2026_validation.csv
scripts/key_moments_dump.json
scripts/__pycache__/

# local-only: Google Apps Script with an embedded API key — never commit
googlesheets_code

# transient local test artifacts
dev-server.log
cp[0-9]*-*.html

# spreadsheet exports (data, kept local)
*.xlsx

# Prod snapshots — JSON dumps of production data used as rollback points.
# Contains real data (titles, speaker names, view counts). Keep local.
backups/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
